pipeline {
  agent {
    docker {
      image 'maven:3.9.9-eclipse-temurin-17'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    SONAR_URL = "http://98.93.245.142:9000"
    APP_DIR = "java-maven-sonar-argocd-helm-k8s/spring-boot-app"
    IMAGE_NAME = "mohdfarhan311/ultimate-cicd:${BUILD_NUMBER}"
  }

  stages {

    stage('Checkout') {
      steps {
        git branch: 'main',
            url: 'https://github.com/MohdFarhan311/Jenkins-Zero-To-Hero.git'
      }
    }

    stage('Setup Docker CLI') {
      steps {
        sh '''
          apt-get update -y
          apt-get install -y docker.io
          docker --version
        '''
      }
    }

    stage('Build and Test') {
      steps {
        sh '''
          cd $APP_DIR
          mvn clean package
        '''
      }
    }

    stage('Static Code Analysis (SonarQube)') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh '''
            cd $APP_DIR
            mvn clean verify sonar:sonar \
              -Dsonar.login=$SONAR_AUTH_TOKEN \
              -Dsonar.host.url=$SONAR_URL
          '''
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        sh '''
          cd $APP_DIR
          docker build -t $IMAGE_NAME .
        '''
      }
    }

    stage('Push Docker Image') {
      steps {
        script {
          def dockerImage = docker.image("${IMAGE_NAME}")
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            dockerImage.push()
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            git config user.email "you@example.com"
            git config user.name "MohdFarhan311"

            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" \
            java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

            git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            git commit -m "Updated image tag ${BUILD_NUMBER}" || true

            git push https://${GITHUB_TOKEN}@github.com/MohdFarhan311/Jenkins-Zero-To-Hero.git HEAD:main
          '''
        }
      }
    }

  }

  post {
    always {
      echo 'Pipeline completed'
    }
    success {
      echo 'Build SUCCESS 🚀'
    }
    failure {
      echo 'Build FAILED ❌'
    }
  }
}
